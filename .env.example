# Generate ONCE with:
#   openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 32 ; echo
# Never change after first deploy — it encrypts existing addon configs,
# changing it invalidates every previously generated user URL.
PRIVATE_ENCRYPTION_KEY=replace_me_with_a_32_char_random_string

# Public URL where this addon is reachable. Used by the addon to generate
# correct Stremio install links. NO trailing slash.
ORIGIN=https://syncribullet.example.com

# Host port to bind on loopback. Default: 3050.
# SYNCRIBULLET_PORT=3050
